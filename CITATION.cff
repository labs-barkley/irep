    given-names: "Elodie Aishwarya P."
    orcid: "https://orcid.org/0009-0004-6031-659X"
version: "0.1.0"
date-released: "2026-07-05"
license: "CC-BY-4.0"
repository-code: "https://github.com/labs-barkley/irep"
url: "https://irepprotocol.org"
keywords:
  - fair hiring
  - open standard
  - hiring discrimination
  - stereotype threat
  - algorithmic fairness
  - equity audit
  - individual baseline
  - longitudinal evaluation
  - EU AI Act
